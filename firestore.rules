rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isApprovedAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.approved == true;
    }

    function isSuperAdmin() {
      return isApprovedAdmin() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'Super Admin';
    }

    function isFirstAdmin() {
      // Allow if no admins collection documents exist yet (bootstrap)
      return !exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Admins Collection ───────────────────────────────────────────────────
    // Stores admin user profiles: { uid, email, firstName, lastName, role,
    //   tel, gender, approved, createdAt }
    match /admins/{adminId} {
      // Any authenticated user can read their own admin doc (to check approval)
      allow read: if isAuthenticated() && (request.auth.uid == adminId || isApprovedAdmin());

      // Allow creating your own admin doc (signup) — bootstrap or pending
      allow create: if isAuthenticated() && request.auth.uid == adminId &&
        request.resource.data.keys().hasAll(['email','firstName','lastName','role','approved','createdAt']);

      // Only super admin or the admin themselves can update; approval changes only by super admin
      allow update: if isAuthenticated() && (
        (request.auth.uid == adminId && !('approved' in request.resource.data.diff(resource.data).affectedKeys())) ||
        isSuperAdmin()
      );

      // Only super admin can delete admin accounts
      allow delete: if isSuperAdmin();
    }

    // ─── Players Collection ──────────────────────────────────────────────────
    // { id, name, number, position, photoURL, bio, status (active|departed),
    //   departedDate, stats: { ppg, reb, ast, gp } }
    match /players/{playerId} {
      allow read: if true;  // Public read
      allow create, update, delete: if isApprovedAdmin();
    }

    // ─── Schedule Collection ─────────────────────────────────────────────────
    // { id, date, opponent, venue, time, isHome, status (upcoming|completed),
    //   ugbScore, opponentScore, result (win|loss|upcoming) }
    match /schedule/{gameId} {
      allow read: if true;  // Public read
      allow create, update, delete: if isApprovedAdmin();
    }

    // ─── Products Collection ─────────────────────────────────────────────────
    // { id, name, category, price, imageURL, description, stock, isNew }
    match /products/{productId} {
      allow read: if true;  // Public read
      allow create, update, delete: if isApprovedAdmin();
    }

    // ─── Orders Collection ───────────────────────────────────────────────────
    // { id, items: [...], total, customerName, customerEmail, customerPhone,
    //   status (pending|fulfilled|cancelled), createdAt }
    match /orders/{orderId} {
      // Anyone can create an order (including anonymous users)
      allow create: if true;
      // Only approved admins can read all orders
      allow read: if isApprovedAdmin();
      // Only approved admins can update order status
      allow update: if isApprovedAdmin();
      // Only super admin can delete orders
      allow delete: if isSuperAdmin();
    }

    // ─── Media Collection ────────────────────────────────────────────────────
    // { id, title, type (highlight|documentary|vlog|spotlight), thumbnailURL,
    //   videoURL, embedCode, viewCount, uploadedBy, createdAt, featured }
    match /media/{mediaId} {
      allow read: if true;  // Public read

      // Any user (including anonymous) can increment viewCount only
      allow update: if
        // Approved admin full update
        isApprovedAdmin() ||
        // Anyone can only increment viewCount by exactly 1
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) &&
          request.resource.data.viewCount == resource.data.viewCount + 1
        );

      allow create: if isApprovedAdmin();
      allow delete: if isApprovedAdmin();
    }

    // ─── Site Settings Collection ─────────────────────────────────────────────
    // { heroText, heroSubtext, featuredMediaId, announcementBanner }
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isApprovedAdmin();
    }

    // ─── Stats Collection ────────────────────────────────────────────────────
    // Aggregated stats for the admin dashboard
    match /stats/{statId} {
      allow read: if isApprovedAdmin();
      allow write: if isApprovedAdmin();
    }

    // ─── Deny All Others ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
