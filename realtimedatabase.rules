{
  "rules": {
    // ─── Live Stats (real-time dashboard counters) ────────────────────────
    "liveStats": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('approved').val() === true"
    },

    // ─── View Counts (10-second view tracking for media) ──────────────────
    // Anyone (authenticated or not) can read, but write is validated:
    //   - Can only increment by 1
    //   - Must be a number
    "viewCounts": {
      "$mediaId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.isNumber() && (
          !data.exists() && newData.val() === 1 ||
          newData.val() === data.val() + 1
        )"
      }
    },

    // ─── Cart Sessions (future: persist carts for logged-in users) ────────
    "cartSessions": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.hasChildren(['items', 'updatedAt'])"
      }
    },

    // ─── Online Presence (track who is online in admin panel) ─────────────
    "onlineAdmins": {
      "$uid": {
        ".read": "auth != null && root.child('admins').child(auth.uid).child('approved').val() === true",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['online', 'lastSeen'])"
      }
    },

    // ─── Match Live Scores (real-time score updates during games) ─────────
    "liveScores": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('approved').val() === true"
    },

    // ─── Deny everything else ─────────────────────────────────────────────
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
